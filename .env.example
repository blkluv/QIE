# Frontend API base URL used by Next.js client components.
NEXT_PUBLIC_API_BASE_URL=/api

# QIE mainnet RPC used by ethers.js. Do not point this app at another chain in production.
NEXT_PUBLIC_QIE_RPC_URL=https://rpc2mainnet.qie.digital

# QIE mainnet chain ID in decimal form, verified from the explorer runtime configuration and RPC eth_chainId.
NEXT_PUBLIC_QIE_CHAIN_ID=1990

# Optional ERC-20 contract address for QUSDC Transfer log detection on QIE mainnet.
NEXT_PUBLIC_QUSDC_CONTRACT=

# Comma-separated origins allowed by the FastAPI backend.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-domain.vercel.app
